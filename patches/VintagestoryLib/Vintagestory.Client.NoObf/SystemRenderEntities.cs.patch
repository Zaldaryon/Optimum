+	private int PrepareOptimumEntityLights()
+	{
+		Optimum.EntityLightBatchBuffer buffer = optimumEntityLightBatchBuffer ??= new Optimum.EntityLightBatchBuffer();
+		int batchId = buffer.NextBatchId();
+		bool measureBatchTime = (batchId & 63) == 0;
+		long startedAt = measureBatchTime ? Stopwatch.GetTimestamp() : 0;
+		int requestCount = 0;
+		int sampleCount = 0;
+		int preparedCount = 0;
+		int chunkGroupCount = 0;
+		int failedChunkGroupCount = 0;
+		int lockBatchCount = 0;
+		int maxBatchSize = 0;
+		try
+		{
+			foreach (KeyValuePair<long, EntityRenderer> entityRenderer in game.EntityRenderers)
+			{
