+				{
+					continue;
+				}
+				int rendererSampleCount = sampler.OptimumLightSampleCount;
+				for (int sampleIndex = 0; sampleIndex < rendererSampleCount; sampleIndex++)
+				{
+					sampleCount++;
+					sampler.GetOptimumLightSampleCoordinates(sampleIndex, out var x, out var y, out var z);
+					if (!game.WorldMap.IsValidPos(x, y, z))
+					{
+						if (PublishOptimumEntityLightSample(sampler, batchId, sampleIndex, x, y, z, null, (ushort)game.WorldMap.SunBrightness, 0))
+						{
+							preparedCount++;
+						}
+						continue;
+					}
+
+					int requestIndex = requestCount;
+					buffer.EnsureCapacity(requestIndex + 1);
+					requestCount = requestIndex + 1;
+					buffer.Samplers[requestIndex] = sampler;
+					buffer.SampleIndexes[requestIndex] = sampleIndex;
+					buffer.X[requestIndex] = x;
+					buffer.Y[requestIndex] = y;
+					buffer.Z[requestIndex] = z;
+					buffer.LocalIndices[requestIndex] = MapUtil.Index3d(x & game.WorldMap.ChunkSizeMask, y & game.WorldMap.ChunkSizeMask, z & game.WorldMap.ChunkSizeMask, 32, 32);
+					buffer.ChunkKeys[requestIndex] = game.WorldMap.ChunkIndex3D(x / 32, y / 32, z / 32);
+					buffer.Order[requestIndex] = requestIndex;
+				}
+			}
+
+			if (requestCount > 1)
+			{
+				Array.Sort(buffer.ChunkKeys, buffer.Order, 0, requestCount);
+			}
+
+			int groupOffset = 0;
+			while (groupOffset < requestCount)
+			{
+				long chunkKey = buffer.ChunkKeys[groupOffset];
+				int groupEnd = groupOffset + 1;
+				while (groupEnd < requestCount && buffer.ChunkKeys[groupEnd] == chunkKey)
+				{
+					groupEnd++;
+				}
+				chunkGroupCount++;
+				IWorldChunk worldChunk = game.WorldMap.GetChunk(chunkKey);
+				if (worldChunk is ClientChunk clientChunk)
+				{
+					int batchOffset = groupOffset;
+					while (batchOffset < groupEnd)
+					{
+						int batchCount = Math.Min(OptimumEntityLightBatchSize, groupEnd - batchOffset);
+						lockBatchCount++;
+						maxBatchSize = Math.Max(maxBatchSize, batchCount);
+						if (!clientChunk.OptimumReadLightBatch(buffer.LocalIndices, buffer.Order, buffer.PackedLights, buffer.Saturations, batchOffset, batchCount))
+						{
+							failedChunkGroupCount++;
+							break;
+						}
+						int batchEnd = batchOffset + batchCount;
+						for (int i = batchOffset; i < batchEnd; i++)
+						{
+							int requestIndex = buffer.Order[i];
+							if (PublishOptimumEntityLightSample(buffer.Samplers[requestIndex], batchId, buffer.SampleIndexes[requestIndex], buffer.X[requestIndex], buffer.Y[requestIndex], buffer.Z[requestIndex], worldChunk, buffer.PackedLights[requestIndex], buffer.Saturations[requestIndex]))
+							{
+								preparedCount++;
+							}
+						}
+						batchOffset = batchEnd;
+					}
+				}
+				else if (worldChunk != null)
+				{
+					failedChunkGroupCount++;
+				}
+				groupOffset = groupEnd;
+			}
+		}
+		catch (Exception e)
+		{
+			batchId = 0;
+			preparedCount = 0;
+			optimumEntityLightBatchDisabled = true;
+			failedChunkGroupCount++;
+			if (!buffer.FailureLogged)
+			{
+				buffer.FailureLogged = true;
+				game.Logger.Warning("Optimum entity light batch failed: {0}", e);
+			}
+		}
+		finally
+		{
+			buffer.ClearSamplers(requestCount);
+			long elapsedTicks = measureBatchTime ? Stopwatch.GetTimestamp() - startedAt : 0;
+			OptimumDiagnostics.RecordEntityLightBatch(sampleCount, preparedCount, chunkGroupCount, failedChunkGroupCount, lockBatchCount, maxBatchSize, elapsedTicks);
+		}
+		return batchId;
+	}
