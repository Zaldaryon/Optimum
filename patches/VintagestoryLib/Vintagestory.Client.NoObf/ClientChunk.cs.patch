+	internal bool OptimumReadLightBatch(int[] localIndices, int[] order, ushort[] packedLights, byte[] saturations, int offset, int count)
+	{
+		if (Disposed)
+		{
+			return false;
+		}
+		lock (packUnpackLock)
+		{
+			if (Disposed)
+			{
+				return false;
+			}
+			Unpack_ReadOnly();
+			ChunkData chunkData = chunkdata;
+			if (chunkData == null)
+			{
+				return false;
+			}
+			int end = offset + count;
+			for (int i = offset; i < end; i++)
+			{
+				int requestIndex = order[i];
+				int saturation;
+				packedLights[requestIndex] = chunkData.ReadLight(localIndices[requestIndex], out saturation);
+				saturations[requestIndex] = (byte)saturation;
+			}
+			return true;
+		}
+	}
