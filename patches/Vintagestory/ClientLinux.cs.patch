--- build/snapshot/Vintagestory/Vintagestory/ClientLinux.cs	2026-07-06 21:36:41.267532800 -0300
+++ build/Vintagestory/Vintagestory/ClientLinux.cs	2026-07-07 21:57:08.318780900 -0300
@@ -1,3 +1,6 @@
+using System;
+using System.IO;
+using System.Linq;
 using Vintagestory.Client;
 
 namespace Vintagestory;
@@ -6,6 +9,26 @@
 {
 	public static void Main(string[] args)
 	{
+		// Optimum: if no --dataPath argument was passed, check for a datapath.cfg
+		// file next to the executable. The installer writes this file when the user
+		// selects a separate data folder, so double-clicking Optimum.exe works the
+		// same as launching from the shortcut that carries the argument.
+		if (!args.Any(a => a.StartsWith("--dataPath", StringComparison.OrdinalIgnoreCase)))
+		{
+			string exeDir = AppContext.BaseDirectory;
+			if (!string.IsNullOrEmpty(exeDir))
+			{
+				string cfgFile = Path.Combine(exeDir, "datapath.cfg");
+				if (File.Exists(cfgFile))
+				{
+					string cfgPath = File.ReadAllText(cfgFile).Trim();
+					if (cfgPath.Length > 0 && Directory.Exists(cfgPath))
+					{
+						args = args.Append("--dataPath=" + cfgPath).ToArray();
+					}
+				}
+			}
+		}
 		ClientProgram.Main(args);
 	}
 }
