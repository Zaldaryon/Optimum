+        public void SetOptimumLightSample(int batchId, int sampleIndex, int x, int y, int z, IWorldChunk sourceChunk, float red, float green, float blue, float sunlight)
+        {
+            if (sampleIndex == 0)
+            {
+                optimumBaseLightBatchId = batchId;
+                optimumBaseLightX = x;
+                optimumBaseLightY = y;
+                optimumBaseLightZ = z;
+                optimumBaseLightChunk = sourceChunk;
+                optimumBaseLightRed = red;
+                optimumBaseLightGreen = green;
+                optimumBaseLightBlue = blue;
+                optimumBaseLightSun = sunlight;
+                return;
+            }
+            if (sampleIndex == 1)
+            {
+                optimumUpperLightBatchId = batchId;
+                optimumUpperLightX = x;
+                optimumUpperLightY = y;
+                optimumUpperLightZ = z;
+                optimumUpperLightChunk = sourceChunk;
+                optimumUpperLightRed = red;
+                optimumUpperLightGreen = green;
+                optimumUpperLightBlue = blue;
+                optimumUpperLightSun = sunlight;
+                return;
+            }
+            throw new ArgumentOutOfRangeException(nameof(sampleIndex));
+        }
+
+        public void ActivateOptimumLightBatch(int batchId)
+        {
+            optimumActiveLightBatchId = batchId;
+            if (batchId == 0)
+            {
+                ClearOptimumLightSamples();
+            }
+        }
+
+        private void ClearOptimumLightSamples()
+        {
+            optimumBaseLightBatchId = 0;
+            optimumBaseLightChunk = null;
+            optimumUpperLightBatchId = 0;
+            optimumUpperLightChunk = null;
+        }
+
+        private bool TryUseOptimumLightSamples(int x, int y, int z, bool needsUpperSample)
+        {
+            int batchId = optimumActiveLightBatchId;
+            optimumActiveLightBatchId = 0;
+            int baseLightBatchId = optimumBaseLightBatchId;
+            int upperLightBatchId = optimumUpperLightBatchId;
+            IWorldChunk baseChunk = optimumBaseLightChunk;
+            IWorldChunk upperChunk = optimumUpperLightChunk;
+            ClearOptimumLightSamples();
+            if (batchId == 0)
+            {
+                return false;
+            }
+
+            bool baseBatchMatches = baseLightBatchId == batchId;
+            bool baseCoordinatesMatch = optimumBaseLightX == x && optimumBaseLightY == y && optimumBaseLightZ == z;
+            bool upperBatchMatches = !needsUpperSample || upperLightBatchId == batchId;
+            bool upperCoordinatesMatch = !needsUpperSample || optimumUpperLightX == x && optimumUpperLightY == y + 1 && optimumUpperLightZ == z;
+            if (!baseBatchMatches || !upperBatchMatches)
+            {
+                return false;
+            }
+            if (!baseCoordinatesMatch || !upperCoordinatesMatch)
+            {
+                OptimumDiagnostics.RecordEntityLightCoordinateMismatch();
+                return false;
+            }
+            if ((baseChunk != null && baseChunk.Disposed) || (needsUpperSample && upperChunk != null && upperChunk.Disposed))
+            {
+                OptimumDiagnostics.RecordEntityLightChunkInvalidation();
+                return false;
+            }
+
+            lightrgbs ??= new Vec4f();
+            if (needsUpperSample && optimumUpperLightSun > optimumBaseLightSun)
+            {
+                lightrgbs.Set(optimumUpperLightRed, optimumUpperLightGreen, optimumUpperLightBlue, optimumUpperLightSun);
+            }
+            else
+            {
+                lightrgbs.Set(optimumBaseLightRed, optimumBaseLightGreen, optimumBaseLightBlue, optimumBaseLightSun);
+            }
+            return true;
+        }
